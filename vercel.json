{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_LOCALE": "vi",
    "APP_FALLBACK_LOCALE": "en",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "array",
    "TRAVEL_PLANNER_CONCURRENCY_DRIVER": "sync"
  }
}
